{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-with-claude"],
  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "http://127.0.0.1:3456",
        "apiKey": "use-cmdline-claude-login"
      }
    },
    "glm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Z.ai GLM",
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4",
        "apiKey": "{file:~/.secrets/opencode/glm-key}"
      },
      "models": {
        "glm-5.2": {
          "name": "GLM-5.2"
        },
        "glm-5-turbo": {
          "name": "GLM-5-Turbo"
        },
        "glm-4.7": {
          "name": "GLM-4.7"
        },
        "glm-4.5-air": {
          "name": "GLM-4.5-Air"
        }
      }
    },
    "minimax": {
      "npm": "@ai-sdk/anthropic",
      "name": "MiniMax",
      "options": {
        "baseURL": "https://api.minimax.io/anthropic/v1",
        "apiKey": "{file:~/.secrets/opencode/minimax-key}"
      },
      "models": {
        "MiniMax-M3": {
          "name": "MiniMax M3"
        },
        "MiniMax-M2.7": {
          "name": "MiniMax M2.7"
        }
      }
    },
    "dmr": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Docker Model Runner",
      "options": {
        "baseURL": "http://localhost:12434/v1"
      },
      "models": {
        "qwen3": {
          "name": "ai/qwen3"
        },
        "gemma4": {
          "name": "ai/gemma4"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"]
    }
  }
}
